# SafeXBets frontend env — copy to `.env.local` and fill in.
# All NEXT_PUBLIC_* vars are exposed to the browser. NEVER put secrets here.

# --- Network: the "flip a switch" toggle (devnet | mainnet-beta) ---
NEXT_PUBLIC_NETWORK=devnet

# --- RPC endpoint (a dedicated devnet RPC is recommended over the public one) ---
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# --- Deployed Anchor program id (from `anchor deploy` on the Mac) ---
# Placeholder until deployed:
NEXT_PUBLIC_PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# --- Principal token mint (6 decimals) ---
# Devnet default: Circle's devnet USDC — anyone can self-fund at https://faucet.circle.com
# (pick "Solana devnet"). The balance chip + betslip faucet links assume this mint.
# On mainnet this becomes the real USDC mint automatically if left blank.
NEXT_PUBLIC_PRINCIPAL_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- TxLINE devnet API token (SERVER-SIDE ONLY — deliberately no NEXT_PUBLIC_ prefix) ---
# Optional. Used by /api/txline/replay/[fixtureId] + /api/txline/fixtures (the matches lobby)
# to pull live data from TxLINE devnet (guest JWT + X-Api-Token). Without it, the bundled
# Brazil vs Norway replay (fixture 18187298) and a sample fixtures slate still work. Get a
# free-tier token per ../docs/TXLINE-API.md. Never expose this to the browser.
# TXLINE_API_TOKEN=
