# Copy to .env and fill in. NEVER commit the real .env.

# --- Network / cluster: the "flip a switch" toggle ---
# devnet | mainnet-beta
NETWORK=devnet
# mock | kamino   (mock on devnet, kamino on mainnet)
YIELD_SOURCE=mock

# --- Program ---
PROGRAM_ID=SxbetsProgram11111111111111111111111111111
# Path to the authority/oracle signer keypair (relayer signs settlement results)
ORACLE_KEYPAIR=./keypairs/oracle.json

# --- TxLINE (TxODDS live football API) — devnet ---
TXLINE_BASE_URL=https://txline-dev.txodds.com/api
TXLINE_JWT_URL=https://txline-dev.txodds.com/auth/guest/start
# Paste the token printed by the free-tier activation flow (docs/TXLINE-API.md).
# Leave blank to run the relayer on offline fixtures.
TXLINE_API_TOKEN=
# TxODDS devnet subscription token mint (Token-2022) — used only during activation.
TXLINE_SUBSCRIPTION_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# --- Token mint used for principal ---
# Devnet default: Circle's official devnet USDC — any user can self-fund at https://faucet.circle.com
# (Alternative: your own mock mint if you want mintable supply. Mainnet: real USDC.)
PRINCIPAL_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- Frontend ---
NEXT_PUBLIC_NETWORK=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=SxbetsProgram11111111111111111111111111111
